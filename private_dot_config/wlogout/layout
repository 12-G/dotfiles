{
  "label" : "suspend",
  "text" : "Suspend",
  "action" : "systemctl suspend",
  "keybind" : "u"
}
{
  "label" : "logout",
  "text" : "Logout",
  "action" : "hyprctl dispatch exit 0",
  "keybind" : "e"
}
{
  "label" : "lock",
  "text" : "Lock",
  "action" : "$HOME/scripts/lockscreen",
  "keybind" : "l"
}
{
  "label" : "reboot",
  "text" : "Reboot",
  "action" : "systemctl reboot",
  "keybind" : "r"
}
{
  "label" : "shutdown",
  "text" : "Shutdown",
  "action" : "systemctl poweroff",
  "keybind" : "s"
}
